      "content": {
        "icon": "⚖️",
        "title": "Bullets or Numbers?",
        "sections": [
          {"type": "text", "content": "Bullets = items in any order"},
          {"type": "text", "content": "Numbers = specific sequence"},
          {"type": "example", "title": "Bullets: Shopping list", "text": "• eggs\n• milk\n• bread"},
          {"type": "example", "title": "Numbers: Recipe", "text": "1. Crack eggs\n2. Add milk\n3. Mix together"}
        ]
      }
    },
    {
      "stepId": "summary",
      "type": "step-card",
      "content": {
        "icon": "✨",
        "title": "Numbers = Order",
        "sections": [
